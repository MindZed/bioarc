generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ChatSession {
  id        String        @id @default(uuid())
  title     String
  userId    String?
  user      User?         @relation(fields: [userId], references: [id])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id])
  role      String
  content   String
  createdAt DateTime    @default(now())
}

model ProjectContext {
  id        String   @id @default(cuid())
  keyword   String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String?
  role         String        @default("USER")
  chatSessions ChatSession[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Telemetry {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())

  // FSM State
  state String

  // Environmental Data
  waterTemp   Float
  airTemp     Float
  humidity    Float
  pressure    Float
  levelCm     Int
  predictedPh Float @default(7.0)
  predictedDo Float @default(6.5)

  // Actuator States
  relayIntake   Boolean
  relayOuttake  Boolean
  relayAir      Boolean
  relayLight    Boolean
  relayAgitator Boolean

  @@index([timestamp(sort: Desc)]) // Optimize for time-series querying
}

model SystemLog {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  level     String // "info", "warning", "critical"
  message   String

  @@index([timestamp(sort: Desc)])
}

model DeviceConfig {
  id        String   @id @default(uuid())
  updatedAt DateTime @updatedAt

  lightOnHr      Int     @default(8)
  lightOffHr     Int     @default(20)
  enableLights   Boolean @default(true)
  enableAir      Boolean @default(true)
  enableAgitator Boolean @default(true)
  enableRefill   Boolean @default(true)
}
